class Solution {
    int diff[][]={{0,-1},{0,1},{-1,0},{1,0}};
    private void dfs(int R,int C,int r,int c,char grid[][])
    {
        grid[r][c]='0';
        for(int i=0;i<4;i++)
        {
            int ar=r+diff[i][0],ac=c+diff[i][1];
            if(ar>=0&&ar<R&&ac>=0&&ac<C&&grid[ar][ac]=='1')
            {
                dfs(R,C,ar,ac,grid);
            }
        }
    }
    public int numIslands(char[][] grid) {
        int R=grid.length,C=grid[0].length;
        int islcnt=0;
        for(int r=0;r<R;r++)
            for(int c=0;c<C;c++)
            {
                if(grid[r][c]=='1')
                {
                    islcnt++;
                    dfs(R,C,r,c,grid);
                }
            }
            return islcnt;
    }
}
